# Supabase project credentials
# Get these from: https://supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Poller WebSocket URL (backend live data)
# Leave empty/unset in development to use ws://localhost:4000
# In production, set to your deployed backend, e.g.:
#   VITE_POLLER_WS=wss://bodaphone-api.fly.dev
VITE_POLLER_WS=
